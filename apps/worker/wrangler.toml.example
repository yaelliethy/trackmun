name = "trackmun-worker"
main = "src/index.ts"
compatibility_date = "2024-03-22"

[[d1_databases]]
binding = "DB"
database_name = "mun-db"
database_id = "REPLACE_WITH_D1_ID"

[[r2_buckets]]
binding = "MEDIA"
bucket_name = "mun-media"

[vars]
ENVIRONMENT = "development"
FRONTEND_URL = "http://localhost:5173"
BREVO_SENDER_EMAIL = "noreply@yourconference.org"
BREVO_SENDER_NAME = "TrackMUN Conference"

# Template IDs (set these after creating templates in Brevo dashboard)
BREVO_WELCOME_TEMPLATE_ID = "1"
BREVO_QR_REMINDER_TEMPLATE_ID = "2"
BREVO_PASSWORD_RESET_TEMPLATE_ID = "3"

# Secrets (set via `wrangler secret put <NAME>`):
# - JWT_SECRET
# - BREVO_API_KEY
# - QR_SECRET

[env.staging]
name = "trackmun-worker-staging"

[env.staging.vars]
ENVIRONMENT = "staging"
FRONTEND_URL = "https://staging.trackmun.app"

[[env.staging.d1_databases]]
binding = "DB"
database_name = "mun-db-staging"
database_id = "REPLACE_WITH_STAGING_D1_ID"

[env.production]
name = "trackmun-worker-prod"

[env.production.vars]
ENVIRONMENT = "production"
FRONTEND_URL = "https://trackmun.app"

[[env.production.d1_databases]]
binding = "DB"
database_name = "mun-db-prod"
database_id = "REPLACE_WITH_PROD_D1_ID"
