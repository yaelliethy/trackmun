BETTER_AUTH_SECRET="your-better-auth-secret-min-32-chars"
BETTER_AUTH_URL="http://localhost:8787"
IMPERSONATION_SECRET="your-long-random-secret"

# Development environment variables for TrackMUN Worker
# Copy this file to .dev.vars and fill in the values
# NEVER commit .dev.vars to git - it contains secrets

# ===========================================
# Brevo Email Configuration
# ===========================================
# Get your API key from https://app.brevo.com/settings/keys/api
# Format: xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_API_KEY="xkeysib-your-brevo-api-key"

# Sender configuration (must be verified in Brevo dashboard)
BREVO_SENDER_EMAIL="noreply@yourconference.org"
BREVO_SENDER_NAME="TrackMUN Conference"

# ===========================================
# Brevo Template IDs
# ===========================================
# Welcome email template
BREVO_WELCOME_TEMPLATE_ID="1"

# QR reminder template
BREVO_QR_REMINDER_TEMPLATE_ID="2"

# Password reset template
BREVO_PASSWORD_RESET_TEMPLATE_ID="3"

# ===========================================
# QR Code Configuration
# ===========================================
# Secret for signing QR codes (HMAC-SHA256)
QR_SECRET="your-qr-secret-key-min-32-chars"

# ===========================================
# Frontend URL
# ===========================================
FRONTEND_URL="http://localhost:3000"
