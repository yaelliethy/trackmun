{
  "name": "@trackmun/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --ip 0.0.0.0",
    "deploy": "wrangler deploy src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:push": "drizzle-kit push:sqlite"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.2.2",
    "@hono/zod-openapi": "^0.18.4",
    "@libsql/client": "^0.5.6",
    "@trackmun/shared": "workspace:*",
    "better-auth": "^1.1.0",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.12.9",
    "jose": "^6.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.1.19",
    "@cloudflare/workers-types": "^4.20260317.1",
    "drizzle-kit": "^0.20.18",
    "typescript": "^5.9.3",
    "vitest": "1.3.0",
    "wrangler": "^3.114.17"
  }
}
