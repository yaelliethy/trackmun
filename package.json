{
  "name": "trackmun",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "db:reset": "sh scripts/clear-sqld.sh && sh scripts/restart-sqld-if-running.sh && sh scripts/db-push-with-retry.sh",
    "db:push:retry": "sh scripts/db-push-with-retry.sh",
    "deploy:worker": "pnpm --filter @trackmun/worker run deploy",
    "deploy:web": "pnpm --filter @trackmun/web run deploy",
    "deploy:all": "pnpm deploy:worker && pnpm deploy:web"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "miniflare": "^4.20260317.2",
    "prettier": "^3.8.1",
    "shadcn": "^4.1.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.0.0"
}
